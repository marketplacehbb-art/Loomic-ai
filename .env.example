# Environment Variables Template

# Server Configuration
NODE_ENV=development
PORT=3000
API_PORT=3001

# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b
# NVIDIA hosted default (override for self-hosted NIM, e.g. http://localhost:8000/v1/chat/completions)
NVIDIA_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
# Optional: if Gemini is routed through OpenRouter in your setup
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Legacy fallback keys (not recommended, keep empty)
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=
VITE_OPENAI_API_KEY=
VITE_OPENROUTER_API_KEY=
VITE_NVIDIA_API_KEY=
VITE_API_URL=
VITE_DEV_API_PROXY_TARGET=http://localhost:3001
VITE_BUILD_SOURCEMAP=false

# Supabase (Optional - Legacy Support)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_OAUTH_STATE_SECRET=your_oauth_state_secret
SUPABASE_INTEGRATION_TOKEN_SECRET=your_integration_token_secret

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX_REQUESTS=100
RATE_LIMIT_GENERATE_WINDOW_MS=60000
RATE_LIMIT_GENERATE_MAX_REQUESTS=10
RATE_LIMIT_GIT_WINDOW_MS=60000
RATE_LIMIT_GIT_MAX_REQUESTS=60
RATE_LIMIT_SECURITY_WINDOW_MS=60000
RATE_LIMIT_SECURITY_MAX_REQUESTS=30
PROJECT_QUOTA_DAILY_REQUEST_LIMIT=25
PROJECT_QUOTA_DAILY_TOKEN_LIMIT=50000

# Release Control / Canary Rollout
RELEASE_MODE=stable
RELEASE_VERSION=2.0.0
RELEASE_KILL_SWITCH=false
RELEASE_CANARY_PERCENT=100
RELEASE_CANARY_ENFORCE=false
RELEASE_CANARY_SALT=ai-builder-release
RELEASE_CANARY_ALLOWLIST_USER_IDS=
RELEASE_DENYLIST_USER_IDS=
RELEASE_ADMIN_TOKEN=

# Observability Alert Thresholds (optional)
OBS_ALERT_MIN_SAMPLE_SIZE=5
OBS_ALERT_MAX_P95_MS=12000
OBS_ALERT_MIN_SUCCESS_RATE=0.90
OBS_ALERT_MAX_FALLBACK_RATE=0.20
OBS_ALERT_MAX_COST_PER_REQUEST_USD=0.03

# Application URL
APP_URL=http://localhost:3000
