{
  "category": "contact",
  "components": [
    {
      "id": "contact-split-map-01",
      "name": "Contact Split with Info",
      "category": "contact",
      "subcategory": "split",
      "tags": {
        "industry": [
          "agency",
          "services",
          "studio"
        ],
        "tone": [
          "clean",
          "modern"
        ],
        "theme": [
          "light"
        ],
        "premium": false
      },
      "code": {
        "framework": "react",
        "styling": "tailwind",
        "snippet": "export default function ContactSplitMap01() {\n  return (\n    <section id=\"contact\" className=\"bg-white px-6 py-24\">\n      <div className=\"mx-auto grid max-w-6xl gap-12 lg:grid-cols-2\">\n        {/* Info */}\n        <div>\n          <p className=\"text-xs font-bold uppercase tracking-[0.25em] text-violet-600\">Kontakt</p>\n          <h2 className=\"mt-3 text-3xl font-extrabold text-slate-900\">Lass uns sprechen</h2>\n          <p className=\"mt-4 text-slate-500\">Wir sind immer offen für neue Projekte, Kooperationen oder einfach ein Kennenlernen.</p>\n          <div className=\"mt-8 space-y-4\">\n            {[\n              { icon: \"📧\", label: \"Email\", value: \"hello@{{projectName}}.de\" },\n              { icon: \"📞\", label: \"Telefon\", value: \"+49 30 123 456 789\" },\n              { icon: \"📍\", label: \"Adresse\", value: \"Musterstraße 12, 10115 Berlin\" },\n            ].map((c) => (\n              <div key={c.label} className=\"flex items-start gap-4\">\n                <div className=\"flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-violet-50 text-lg\">{c.icon}</div>\n                <div>\n                  <p className=\"text-xs font-semibold uppercase tracking-wide text-slate-400\">{c.label}</p>\n                  <p className=\"mt-0.5 text-sm text-slate-700\">{c.value}</p>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n        {/* Form */}\n        <div className=\"rounded-3xl border border-slate-200 bg-slate-50 p-8\">\n          <div className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div>\n                <label className=\"mb-1 block text-xs font-semibold text-slate-500\">Vorname</label>\n                <input className=\"w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100\" />\n              </div>\n              <div>\n                <label className=\"mb-1 block text-xs font-semibold text-slate-500\">Nachname</label>\n                <input className=\"w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100\" />\n              </div>\n            </div>\n            <div>\n              <label className=\"mb-1 block text-xs font-semibold text-slate-500\">E-Mail</label>\n              <input className=\"w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100\" />\n            </div>\n            <div>\n              <label className=\"mb-1 block text-xs font-semibold text-slate-500\">Nachricht</label>\n              <textarea rows={4} className=\"w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100 resize-none\" />\n            </div>\n            <button type=\"button\" className=\"w-full rounded-xl bg-violet-600 py-3 text-sm font-bold text-white transition hover:bg-violet-500\">\n              Nachricht senden\n            </button>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}"
      }
    },
